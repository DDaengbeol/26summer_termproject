<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_white"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로가기"
            android:padding="8dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="메모 작성"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/saveExcerptButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:gravity="center"
            android:text="저장"
            android:textColor="@color/ios_blue"
            android:textSize="17sp" />
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="페이지 번호"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/pageEditText"
                    android:layout_width="116dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_page_chip"
                    android:hint="P. 153"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/scan_teal"
                    android:textColorHint="@color/scan_teal"
                    android:textSize="18sp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/captureTextButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="카메라 촬영"
                    android:padding="6dp"
                    android:src="@drawable/ic_camera_outline" />

                <ImageButton
                    android:id="@+id/galleryImageButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="사진 선택"
                    android:padding="6dp"
                    android:src="@drawable/ic_image_outline" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_photo_frame">

                <androidx.camera.view.PreviewView
                    android:id="@+id/cameraPreviewView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/deleteScanImageButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="end|bottom"
                    android:layout_margin="12dp"
                    android:background="@drawable/bg_memo_box"
                    android:contentDescription="사진 삭제"
                    android:padding="8dp"
                    android:src="@drawable/ic_trash" />
            </FrameLayout>

            <EditText
                android:id="@+id/recognizedTextEditText"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_memo_box"
                android:gravity="top"
                android:hint="추출된 문장을 확인하고 수정하세요."
                android:inputType="textMultiLine"
                android:minLines="7"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="18sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
