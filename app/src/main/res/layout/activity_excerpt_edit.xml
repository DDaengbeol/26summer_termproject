<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="89dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageButton
            android:id="@+id/excerptEditBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:contentDescription="뒤로가기"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back_24" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/saveExcerptEditButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:contentDescription="저장"
            android:padding="10dp"
            android:src="@drawable/ic_check_24" />

        <ImageButton
            android:id="@+id/deleteExcerptEditButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@android:color/transparent"
            android:contentDescription="삭제"
            android:padding="10dp"
            android:src="@drawable/ic_delete_24" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EFEFF0" />

    <EditText
        android:id="@+id/editExcerptContentEditText"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_marginStart="34dp"
        android:layout_marginTop="34dp"
        android:layout_marginEnd="34dp"
        android:background="@drawable/bg_memo_card"
        android:gravity="top"
        android:hint="발췌를 입력하세요"
        android:inputType="textMultiLine"
        android:padding="24dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/editExcerptPageEditText"
        android:layout_width="110dp"
        android:layout_height="44dp"
        android:layout_marginStart="34dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_memo_card"
        android:gravity="center"
        android:hint="쪽"
        android:inputType="number"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="34dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="34dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/extractTextButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="텍스트 추출" />

        <Button
            android:id="@+id/saveExcerptImageButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="이미지 저장" />
    </LinearLayout>
</LinearLayout>
