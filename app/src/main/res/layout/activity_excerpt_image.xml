<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEE4D6"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/image_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="18dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로가기"
            android:padding="7dp"
            android:src="@drawable/ic_back"
            android:tint="#FFFFFF" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/saveImageButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:drawableStart="@drawable/ic_download"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="저장"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/shareExcerptImageButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="22dp"
            android:drawableStart="@drawable/ic_share"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:text="공유하기"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@color/image_black" />

    <TextView
        android:id="@+id/excerptPreviewTextView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_excerpt_canvas"
        android:gravity="center_vertical"
        android:lineSpacingExtra="5dp"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:textColor="#241B18"
        android:textSize="21sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@color/image_black" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:background="@color/image_dark"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="12dp"
        android:paddingEnd="22dp"
        android:paddingBottom="16dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/ratioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_dark_pill"
                    android:gravity="center"
                    android:text="1:1"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/scaleButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_dark_pill"
                    android:gravity="center"
                    android:text="x 1.00"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/lightStyleButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_dark_pill"
                    android:gravity="center"
                    android:text="단색"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/darkStyleButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_dark_pill"
                    android:gravity="center"
                    android:text="그라데이션"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/imageStyleButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_dark_pill_selected"
                    android:gravity="center"
                    android:text="이미지"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_excerpt_canvas" />

            <View
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:background="@color/image_black" />

            <View
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:background="@color/primary" />

            <View
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="10dp"
                android:background="@color/accent" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
