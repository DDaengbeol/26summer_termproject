<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp">

        <ImageButton
            android:id="@+id/bookSearchBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_header_search_button"
            android:contentDescription="뒤로가기"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back_24" />

        <EditText
            android:id="@+id/bookSearchEditText"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_item"
            android:hint="책 제목 또는 저자"
            android:imeOptions="actionSearch"
            android:inputType="textNoSuggestions|textMultiLine"
            android:maxLines="1"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/bookSearchSubmitButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_header_search_button"
            android:contentDescription="@string/search_books"
            android:padding="10dp"
            android:src="@drawable/ic_search_24" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/bookSearchProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <TextView
        android:id="@+id/bookSearchEmptyTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        android:text="알라딘에서 책을 검색해 등록하세요."
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/bookSearchRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp" />
</LinearLayout>
